# Travel Fare Engine — local environment template. Copy to .env (git-ignored).

# --- Server -----------------------------------------------------------------
# Local listen port (Cloud Run injects $PORT in prod; main.go defaults to 8081).
PORT=8081

# URL advertised in the agent card's supportedInterfaces[].url. Locally this can
# be left unset (falls back to http://localhost:$PORT). In Cloud Run, set it to
# the service URL or the orchestrator's discovery will point at localhost.
# HOST_URL=https://travel-fare-engine-xxxx.run.app/

# --- Model backend ----------------------------------------------------------
# Pick ONE path.

# (A) Local dev — AI Studio Gemini API key.
GEMINI_API_KEY=your-api-key-here

# (B) Production — Vertex AI (uses Application Default Credentials, no API key).
# Set these instead of GEMINI_API_KEY:
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
